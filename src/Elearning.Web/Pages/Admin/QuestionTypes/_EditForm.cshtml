@model Elearning.Web.Pages.Admin.QuestionTypes.EditModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<form method="post" asp-page-handler="Modal" class="row g-3" data-admin-ajax-form="true" data-admin-refresh-target="#questionTypesTable">
    <abp-validation-summary />

    <div class="col-md-6">
        <label asp-for="Input.Code" class="form-label">@L["QuestionTypes:Code"]</label>
        <input asp-for="Input.Code" class="form-control" readonly />
        <span asp-validation-for="Input.Code" class="text-danger"></span>
        <div class="form-text">@L["QuestionTypes:CodeReadonlyHelp"]</div>
    </div>

    <div class="col-md-6">
        <label asp-for="Input.DisplayName" class="form-label">@L["QuestionTypes:DisplayName"]</label>
        <input asp-for="Input.DisplayName" class="form-control" />
        <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Input.Description" class="form-label">@L["QuestionTypes:Description"]</label>
        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Input.InputKind" class="form-label">@L["QuestionTypes:InputKind"]</label>
        <select asp-for="Input.InputKind" asp-items="Model.InputKindOptions" class="form-select"></select>
    </div>

    <div class="col-md-4">
        <label asp-for="Input.ScoringKind" class="form-label">@L["QuestionTypes:ScoringKind"]</label>
        <select asp-for="Input.ScoringKind" asp-items="Model.ScoringKindOptions" class="form-select"></select>
    </div>

    <div class="col-md-4">
        <label asp-for="Input.SortOrder" class="form-label">@L["QuestionTypes:SortOrder"]</label>
        <input asp-for="Input.SortOrder" class="form-control" />
        <span asp-validation-for="Input.SortOrder" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Input.MinimumOptions" class="form-label">@L["QuestionTypes:MinimumOptions"]</label>
        <input asp-for="Input.MinimumOptions" class="form-control" />
        <span asp-validation-for="Input.MinimumOptions" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Input.MaximumOptions" class="form-label">@L["QuestionTypes:MaximumOptions"]</label>
        <input asp-for="Input.MaximumOptions" class="form-control" />
        <span asp-validation-for="Input.MaximumOptions" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <div class="form-check">
            <input asp-for="Input.SupportsOptions" class="form-check-input" />
            <label asp-for="Input.SupportsOptions" class="form-check-label">@L["QuestionTypes:SupportsOptions"]</label>
        </div>
        <div class="form-check">
            <input asp-for="Input.SupportsAnswerPairs" class="form-check-input" />
            <label asp-for="Input.SupportsAnswerPairs" class="form-check-label">@L["QuestionTypes:SupportsAnswerPairs"]</label>
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-check">
            <input asp-for="Input.RequiresManualGrading" class="form-check-input" />
            <label asp-for="Input.RequiresManualGrading" class="form-check-label">@L["QuestionTypes:RequiresManualGrading"]</label>
        </div>
        <div class="form-check">
            <input asp-for="Input.AllowMultipleCorrectAnswers" class="form-check-input" />
            <label asp-for="Input.AllowMultipleCorrectAnswers" class="form-check-label">@L["QuestionTypes:AllowMultipleCorrectAnswers"]</label>
        </div>
    </div>

    <div class="col-12">
        <span class="badge @(Model.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
            @(Model.IsActive ? L["QuestionTypes:IsActive"] : L["QuestionTypes:Inactive"])
        </span>
        @if (Model.IsSystem)
        {
            <span class="badge bg-info-subtle text-info-emphasis">@L["QuestionTypes:System"]</span>
        }
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@L["QuestionTypes:Save"]</button>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@L["QuestionTypes:Cancel"]</button>
    </div>
</form>
