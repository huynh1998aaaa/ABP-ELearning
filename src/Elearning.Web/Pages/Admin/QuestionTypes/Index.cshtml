@page "/admin/questiontypes"
@model Elearning.Web.Pages.Admin.QuestionTypes.IndexModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin">@L["QuestionTypes:BackToAdmin"]</a>
    <h1 class="h3 mb-1">@L["QuestionTypes:ListTitle"]</h1>
    <p class="text-muted mb-0">@L["QuestionTypes:ListSubtitle"]</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["QuestionTypes:Stats:Total"]</span>
                <div class="fs-2 fw-bold">@Model.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["QuestionTypes:Stats:Active"]</span>
                <div class="fs-2 fw-bold">@Model.ActiveCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["QuestionTypes:Stats:Inactive"]</span>
                <div class="fs-2 fw-bold">@Model.InactiveCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["QuestionTypes:Stats:System"]</span>
                <div class="fs-2 fw-bold">@Model.SystemCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <span class="fw-semibold">@L["QuestionTypes:Title"]</span>
        @if (Model.CanCreate)
        {
            <a class="btn btn-primary btn-sm" href="/admin/questiontypes/create">@L["QuestionTypes:Create"]</a>
        }
    </div>
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-lg-8">
                <input asp-for="Filter" class="form-control" placeholder="@L["QuestionTypes:SearchPlaceholder"]" />
            </div>
            <div class="col-lg-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["QuestionTypes:Search"]</button>
                <a class="btn btn-outline-secondary" href="/admin/questiontypes">@L["QuestionTypes:Reset"]</a>
            </div>
        </form>

        @if (Model.QuestionTypes.Count == 0)
        {
            <div class="alert alert-light border">@L["QuestionTypes:NoItems"]</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>@L["QuestionTypes:Code"]</th>
                            <th>@L["QuestionTypes:DisplayName"]</th>
                            <th>@L["QuestionTypes:InputKind"]</th>
                            <th>@L["QuestionTypes:ScoringKind"]</th>
                            <th>@L["QuestionTypes:SortOrder"]</th>
                            <th>@L["QuestionTypes:Status"]</th>
                            <th class="text-end">@L["QuestionTypes:Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var questionType in Model.QuestionTypes)
                        {
                            <tr>
                                <td><code>@questionType.Code</code></td>
                                <td>
                                    <strong>@questionType.DisplayName</strong>
                                    @if (questionType.IsSystem)
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis ms-1">@L["QuestionTypes:System"]</span>
                                    }
                                </td>
                                <td>@L[$"Enum:QuestionInputKind:{questionType.InputKind}"]</td>
                                <td>@L[$"Enum:QuestionScoringKind:{questionType.ScoringKind}"]</td>
                                <td>@questionType.SortOrder</td>
                                <td>
                                    <span class="badge @(questionType.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                                        @(questionType.IsActive ? L["QuestionTypes:IsActive"] : L["QuestionTypes:Inactive"])
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        @if (Model.CanUpdate)
                                        {
                                            <a class="btn btn-sm btn-outline-primary" href="/admin/questiontypes/edit/@questionType.Id">@L["QuestionTypes:Edit"]</a>
                                            @if (questionType.IsActive)
                                            {
                                                <form method="post" asp-page-handler="Deactivate" asp-route-id="@questionType.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">@L["QuestionTypes:Deactivate"]</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="Activate" asp-route-id="@questionType.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-success">@L["QuestionTypes:Activate"]</button>
                                                </form>
                                            }
                                        }
                                        @if (Model.CanDelete && !questionType.IsSystem)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@questionType.Id" onsubmit="return confirm('@L["QuestionTypes:ConfirmDelete"]');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">@L["QuestionTypes:Delete"]</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Question types pagination" class="d-flex justify-content-between align-items-center mt-3">
                <span>@L["QuestionTypes:Page"] @Model.CurrentPage / @Model.TotalPages</span>
                <div class="d-flex gap-2">
                    @if (Model.CurrentPage > 1)
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
                    }
                </div>
            </nav>
        }
    </div>
</div>
