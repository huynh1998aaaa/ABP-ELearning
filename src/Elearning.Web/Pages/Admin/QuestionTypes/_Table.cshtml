@model Elearning.Web.Pages.Admin.QuestionTypes.IndexModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

@if (Model.QuestionTypes.Count == 0)
{
    <div class="alert alert-light border">@L["QuestionTypes:NoItems"]</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["QuestionTypes:Code"]</th>
                    <th>@L["QuestionTypes:DisplayName"]</th>
                    <th>@L["QuestionTypes:InputKind"]</th>
                    <th>@L["QuestionTypes:ScoringKind"]</th>
                    <th>@L["QuestionTypes:SortOrder"]</th>
                    <th>@L["QuestionTypes:Status"]</th>
                    <th class="text-end">@L["QuestionTypes:Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var questionType in Model.QuestionTypes)
                {
                    <tr>
                        <td><code>@questionType.Code</code></td>
                        <td>
                            <strong>@questionType.DisplayName</strong>
                            @if (questionType.IsSystem)
                            {
                                <span class="badge bg-info-subtle text-info-emphasis ms-1">@L["QuestionTypes:System"]</span>
                            }
                        </td>
                        <td>@L[$"Enum:QuestionInputKind:{questionType.InputKind}"]</td>
                        <td>@L[$"Enum:QuestionScoringKind:{questionType.ScoringKind}"]</td>
                        <td>@questionType.SortOrder</td>
                        <td>
                            <span class="badge @(questionType.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                                @(questionType.IsActive ? L["QuestionTypes:IsActive"] : L["QuestionTypes:Inactive"])
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                @if (Model.CanUpdate)
                                {
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/admin/questiontypes/edit/@questionType.Id"
                                       data-admin-modal-url="/admin/questiontypes/edit/@questionType.Id?handler=Modal"
                                       data-admin-modal-title="@L["QuestionTypes:EditTitle"]"
                                       data-admin-modal-size="lg">@L["QuestionTypes:Edit"]</a>
                                    @if (questionType.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@questionType.Id" data-admin-ajax-form="true" data-admin-refresh-target="#questionTypesTable">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">@L["QuestionTypes:Deactivate"]</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Activate" asp-route-id="@questionType.Id" data-admin-ajax-form="true" data-admin-refresh-target="#questionTypesTable">
                                            <button type="submit" class="btn btn-sm btn-outline-success">@L["QuestionTypes:Activate"]</button>
                                        </form>
                                    }
                                }
                                @if (Model.CanDelete && !questionType.IsSystem)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@questionType.Id" data-admin-ajax-form="true" data-admin-refresh-target="#questionTypesTable" onsubmit="return confirm('@L["QuestionTypes:ConfirmDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["QuestionTypes:Delete"]</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Question types pagination" class="d-flex justify-content-between align-items-center mt-3">
        <span>@L["QuestionTypes:Page"] @Model.CurrentPage / @Model.TotalPages</span>
        <div class="d-flex gap-2">
            @if (Model.CurrentPage > 1)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
            }
        </div>
    </nav>
}
