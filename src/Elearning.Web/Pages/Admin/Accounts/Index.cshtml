@page "/admin/accounts"
@model Elearning.Web.Pages.Admin.Accounts.IndexModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin">@L["Accounts:BackToAdmin"]</a>
    <h1 class="h3 mb-1">@L["Accounts:ListTitle"]</h1>
    <p class="text-muted mb-0">@L["Accounts:ListSubtitle"]</p>
</div>

<div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                <span>@L["Accounts:Stats:Users"]</span>
                <div class="fs-2 fw-bold">@Model.TotalCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                <span>@L["Accounts:Stats:Active"]</span>
                <div class="fs-2 fw-bold">@Model.ActiveCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                <span>@L["Accounts:Stats:Inactive"]</span>
                <div class="fs-2 fw-bold">@Model.InactiveCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                <span>@L["Accounts:Stats:Admins"]</span>
                <div class="fs-2 fw-bold">@Model.AdminCount</div>
                </div>
            </div>
        </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <span class="fw-semibold">@L["Accounts:Title"]</span>
        @if (Model.CanCreate)
        {
            <a class="btn btn-primary btn-sm" href="/admin/accounts/create">@L["Accounts:Create"]</a>
        }
    </div>
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-lg-8">
                <input asp-for="Filter" class="form-control" placeholder="@L["Accounts:SearchPlaceholder"]" />
            </div>
            <div class="col-lg-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["Accounts:Search"]</button>
                <a class="btn btn-outline-secondary" href="/admin/accounts">@L["Accounts:Reset"]</a>
            </div>
        </form>

        @if (Model.Users.Count == 0)
        {
            <div class="alert alert-light border">@L["Accounts:NoUsers"]</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>@L["Accounts:UserName"]</th>
                            <th>@L["Accounts:Name"]</th>
                            <th>@L["Accounts:Email"]</th>
                            <th>@L["Accounts:Phone"]</th>
                            <th>@L["Accounts:Status"]</th>
                            <th>@L["Accounts:CreatedAt"]</th>
                            <th class="text-end">@L["Accounts:Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td><strong>@user.UserName</strong></td>
                                <td>@user.DisplayName</td>
                                <td>@user.Email</td>
                                <td>@user.PhoneNumber</td>
                                <td>
                                    <span class="badge @(user.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                                        @(user.IsActive ? L["Accounts:IsActive"] : L["Accounts:Inactive"])
                                    </span>
                                </td>
                                <td>@user.CreationTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        @if (Model.CanUpdate)
                                        {
                                            <a class="btn btn-sm btn-outline-primary" href="/admin/accounts/edit/@user.Id">@L["Accounts:Edit"]</a>
                                        }
                                        @if (Model.CanDelete)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" onsubmit="return confirm('@L["Accounts:ConfirmDelete"]');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">@L["Accounts:Delete"]</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Accounts pagination" class="d-flex justify-content-between align-items-center mt-3">
                <span>@L["Accounts:Page"] @Model.CurrentPage / @Model.TotalPages</span>
                <div class="d-flex gap-2">
                    @if (Model.CurrentPage > 1)
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
                    }
                </div>
            </nav>
        }
    </div>
</div>
