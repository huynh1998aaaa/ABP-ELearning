@page "/admin"
@model Elearning.Web.Pages.Admin.IndexModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

@{
    var hasUserPremium = Model.CanManageAccounts || Model.CanManagePremium;
    var hasContentBank = Model.CanManageQuestionTypes || Model.CanManageSubjects || Model.CanManageQuestions;
    var hasDelivery = Model.CanManageExams || Model.CanManagePractices;
    var hasAnyModule = hasUserPremium || hasContentBank || hasDelivery;
    var currentUserName = User.Identity?.Name ?? L["Menu:Admin"].Value;
}

<section class="section-panel admin-simple-shell">
    <header class="admin-simple-topbar">
        <a class="admin-simple-brand" href="/admin">
            <span>OMD.TestGo</span>
            <strong>Admin</strong>
        </a>

        <nav class="admin-simple-nav" aria-label="@L["Admin:Dashboard:Simple:Overview"]">
            @if (hasUserPremium)
            {
                <a href="#admin-accounts">@L["Admin:Dashboard:Simple:AccountsNav"]</a>
            }
            @if (hasContentBank)
            {
                <a href="#admin-content">@L["Admin:Dashboard:Simple:ContentNav"]</a>
            }
            @if (hasDelivery)
            {
                <a href="#admin-delivery">@L["Admin:Dashboard:Simple:DeliveryNav"]</a>
            }
        </nav>

        <div class="admin-simple-user">
            <span>@currentUserName</span>
            <a href="/Account/Logout">@L["Admin:Dashboard:Simple:SignOut"]</a>
        </div>
    </header>

    <div class="admin-simple-layout">
        <div class="admin-simple-hero">
            <span class="admin-simple-eyebrow">@L["Admin:Dashboard:Simple:HeroEyebrow"]</span>
            <h1>@L["Admin:Dashboard:Simple:HeroTitle"]</h1>
            <p>@L["Admin:Dashboard:Simple:HeroSubtitle"]</p>

            @if (Model.CanImportQuestions || Model.CanManageExams || Model.CanManagePremium)
            {
                <div class="admin-simple-actions">
                    @if (Model.CanImportQuestions)
                    {
                        <a class="btn btn-primary" href="/admin/questions/import">@L["Admin:Dashboard:Simple:ImportQuestions"]</a>
                    }
                    @if (Model.CanManageExams)
                    {
                        <a class="btn btn-outline-dark" href="/admin/exams/create">@L["Admin:Dashboard:Simple:CreateExam"]</a>
                    }
                    @if (Model.CanManagePremium)
                    {
                        <a class="btn btn-outline-dark" href="/admin/premiumsubscriptions">@L["Admin:Dashboard:Simple:ManagePremium"]</a>
                    }
                </div>
            }
        </div>

        <aside class="admin-simple-attention">
            <span>@L["Admin:Dashboard:Simple:AttentionTitle"]</span>
            <h2>@L["Admin:Dashboard:Simple:AttentionSubtitle"]</h2>
            <div class="admin-simple-attention-list">
                @if (Model.CanManageQuestions)
                {
                    <a href="/admin/questions?status=Draft">@L["Admin:Dashboard:Simple:AttentionQuestions"]</a>
                }
                @if (Model.CanManagePremium)
                {
                    <a href="/admin/premiumsubscriptions">@L["Admin:Dashboard:Simple:AttentionPremium"]</a>
                }
                @if (Model.CanManageExams)
                {
                    <a href="/admin/exams">@L["Admin:Dashboard:Simple:AttentionExams"]</a>
                }
                @if (!Model.CanManageQuestions && !Model.CanManagePremium && !Model.CanManageExams)
                {
                    <p>@L["Admin:Dashboard:NoPermission"]</p>
                }
            </div>
        </aside>
    </div>

    <div class="admin-simple-kpis" aria-label="@L["Admin:Dashboard:Simple:Overview"]">
        <article>
            <span>@L["Admin:Dashboard:Simple:KpiAccounts"]</span>
            <strong>@L["Admin:Dashboard:Simple:KpiAccountsValue"]</strong>
            <p>@L["Admin:Dashboard:Simple:KpiAccountsHint"]</p>
        </article>
        <article>
            <span>@L["Admin:Dashboard:Simple:KpiPremium"]</span>
            <strong>@L["Admin:Dashboard:Simple:KpiPremiumValue"]</strong>
            <p>@L["Admin:Dashboard:Simple:KpiPremiumHint"]</p>
        </article>
        <article>
            <span>@L["Admin:Dashboard:Simple:KpiQuestions"]</span>
            <strong>@L["Admin:Dashboard:Simple:KpiQuestionsValue"]</strong>
            <p>@L["Admin:Dashboard:Simple:KpiQuestionsHint"]</p>
        </article>
        <article>
            <span>@L["Admin:Dashboard:Simple:KpiDelivery"]</span>
            <strong>@L["Admin:Dashboard:Simple:KpiDeliveryValue"]</strong>
            <p>@L["Admin:Dashboard:Simple:KpiDeliveryHint"]</p>
        </article>
    </div>

    <div class="admin-simple-heading">
        <span>@L["Admin:Dashboard:Simple:ModulesTitle"]</span>
        <p>@L["Admin:Dashboard:Simple:ModulesSubtitle"]</p>
    </div>

    <div class="admin-simple-modules">
        @if (hasUserPremium)
        {
            <article class="admin-simple-card" id="admin-accounts">
                <div>
                    <span class="admin-simple-icon">A</span>
                    <h2>@L["Admin:Dashboard:Simple:UserPremiumTitle"]</h2>
                    <p>@L["Admin:Dashboard:Simple:UserPremiumDescription"]</p>
                </div>
                <div class="admin-simple-links">
                    @if (Model.CanManageAccounts)
                    {
                        <a href="/admin/accounts">@L["Accounts:OpenManagement"]</a>
                        <a href="/admin/accounts/create">@L["Accounts:Create"]</a>
                    }
                    @if (Model.CanManagePremium)
                    {
                        <a href="/admin/premiumsubscriptions">@L["PremiumSubscriptions:Title"]</a>
                        <a href="/admin/premiumsubscriptions/create">@L["PremiumSubscriptions:Create"]</a>
                    }
                </div>
            </article>
        }

        @if (hasContentBank)
        {
            <article class="admin-simple-card" id="admin-content">
                <div>
                    <span class="admin-simple-icon">Q</span>
                    <h2>@L["Admin:Dashboard:Simple:QuestionBankTitle"]</h2>
                    <p>@L["Admin:Dashboard:Simple:QuestionBankDescription"]</p>
                </div>
                <div class="admin-simple-links">
                    @if (Model.CanManageQuestionTypes)
                    {
                        <a href="/admin/questiontypes">@L["QuestionTypes:Title"]</a>
                        <a href="/admin/questiontypes/create">@L["QuestionTypes:Create"]</a>
                    }
                    @if (Model.CanManageSubjects)
                    {
                        <a href="/admin/subjects">@L["Subjects:Title"]</a>
                        <a href="/admin/subjects/create">@L["Subjects:Create"]</a>
                    }
                    @if (Model.CanManageQuestions)
                    {
                        <a href="/admin/questions">@L["Questions:Title"]</a>
                    }
                    @if (Model.CanImportQuestions)
                    {
                        <a href="/admin/questions/import">@L["Admin:Dashboard:Simple:ImportNow"]</a>
                    }
                </div>
            </article>
        }

        @if (hasDelivery)
        {
            <article class="admin-simple-card" id="admin-delivery">
                <div>
                    <span class="admin-simple-icon">E</span>
                    <h2>@L["Admin:Dashboard:Simple:DeliveryTitle"]</h2>
                    <p>@L["Admin:Dashboard:Simple:DeliveryDescription"]</p>
                </div>
                <div class="admin-simple-links">
                    @if (Model.CanManageExams)
                    {
                        <a href="/admin/exams">@L["Exams:Title"]</a>
                        <a href="/admin/exams/create">@L["Admin:Dashboard:Simple:CreateExamNow"]</a>
                    }
                    @if (Model.CanManageExamQuestions)
                    {
                        <a href="/admin/exams">@L["Exams:ManageQuestions"]</a>
                    }
                    @if (Model.CanManagePractices)
                    {
                        <a href="/admin/practices">@L["Practices:Title"]</a>
                    }
                    @if (Model.CanManagePracticeQuestions)
                    {
                        <a href="/admin/practices">@L["Practices:ManageQuestions"]</a>
                    }
                </div>
            </article>
        }
    </div>

    @if (!hasAnyModule)
    {
        <div class="alert alert-light border mt-4">
            @L["Admin:Dashboard:NoPermission"]
        </div>
    }
</section>
