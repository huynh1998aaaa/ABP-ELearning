@page "/admin/exams/edit/{id:guid}"
@model Elearning.Web.Pages.Admin.Exams.EditModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin/exams">@L["Exams:BackToList"]</a>
    <h1 class="h3 mb-1">@L["Exams:EditTitle"]</h1>
    <p class="text-muted mb-0">@L["Exams:EditDescription"]</p>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" class="row g-3">
            <abp-validation-summary />
            <div class="col-md-4"><label asp-for="Input.Code" class="form-label">@L["Exams:Code"]</label><input asp-for="Input.Code" class="form-control" /></div>
            <div class="col-md-8"><label asp-for="Input.Title" class="form-label">@L["Exams:TitleColumn"]</label><input asp-for="Input.Title" class="form-control" /></div>
            <div class="col-12"><label asp-for="Input.Description" class="form-label">@L["Exams:Description"]</label><textarea asp-for="Input.Description" class="form-control" rows="3"></textarea></div>
            <div class="col-md-3"><label asp-for="Input.AccessLevel" class="form-label">@L["Exams:AccessLevel"]</label><select asp-for="Input.AccessLevel" asp-items="Model.AccessLevelOptions" class="form-select"></select></div>
            <div class="col-md-3"><label asp-for="Input.SelectionMode" class="form-label">@L["Exams:SelectionMode"]</label><select asp-for="Input.SelectionMode" asp-items="Model.SelectionModeOptions" class="form-select"></select></div>
            <div class="col-md-3"><label asp-for="Input.DurationMinutes" class="form-label">@L["Exams:DurationMinutes"]</label><input asp-for="Input.DurationMinutes" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Input.TotalQuestionCount" class="form-label">@L["Exams:TotalQuestionCount"]</label><input asp-for="Input.TotalQuestionCount" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="Input.PassingScore" class="form-label">@L["Exams:PassingScore"]</label><input asp-for="Input.PassingScore" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="Input.SortOrder" class="form-label">@L["Exams:SortOrder"]</label><input asp-for="Input.SortOrder" class="form-control" /></div>
            <div class="col-md-6"><div class="form-check"><input asp-for="Input.ShuffleQuestions" class="form-check-input" /><label asp-for="Input.ShuffleQuestions" class="form-check-label">@L["Exams:ShuffleQuestions"]</label></div></div>
            <div class="col-md-6"><div class="form-check"><input asp-for="Input.ShuffleOptions" class="form-check-input" /><label asp-for="Input.ShuffleOptions" class="form-check-label">@L["Exams:ShuffleOptions"]</label></div></div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["Exams:Save"]</button>
                <a class="btn btn-outline-secondary" href="/admin/exams">@L["Exams:Cancel"]</a>
            </div>
        </form>
    </div>
</div>
