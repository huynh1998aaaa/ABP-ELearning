@page "/admin/exams"
@model Elearning.Web.Pages.Admin.Exams.IndexModel
@using Elearning.Exams
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin">@L["Exams:BackToAdmin"]</a>
    <h1 class="h3 mb-1">@L["Exams:ListTitle"]</h1>
    <p class="text-muted mb-0">@L["Exams:ListSubtitle"]</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6"><div class="card h-100"><div class="card-body"><span>@L["Exams:Stats:Total"]</span><div class="fs-2 fw-bold">@Model.TotalCount</div></div></div></div>
    <div class="col-xl-3 col-md-6"><div class="card h-100"><div class="card-body"><span>@L["Exams:Stats:Published"]</span><div class="fs-2 fw-bold">@Model.PublishedCount</div></div></div></div>
    <div class="col-xl-3 col-md-6"><div class="card h-100"><div class="card-body"><span>@L["Exams:Stats:Draft"]</span><div class="fs-2 fw-bold">@Model.DraftCount</div></div></div></div>
    <div class="col-xl-3 col-md-6"><div class="card h-100"><div class="card-body"><span>@L["Exams:Stats:Archived"]</span><div class="fs-2 fw-bold">@Model.ArchivedCount</div></div></div></div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <span class="fw-semibold">@L["Exams:Title"]</span>
        @if (Model.CanCreate)
        {
            <a class="btn btn-primary btn-sm"
               href="/admin/exams/create"
               data-admin-modal-url="/admin/exams/create?handler=Modal"
               data-admin-modal-title="@L["Exams:CreateTitle"]"
               data-admin-modal-size="lg">@L["Exams:Create"]</a>
        }
    </div>
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-lg-3">
                <input asp-for="Filter" class="form-control" placeholder="@L["Exams:SearchPlaceholder"]" />
            </div>
            <div class="col-lg-2">
                <select asp-for="Status" class="form-select">
                    <option value="">@L["Exams:AllStatuses"]</option>
                    @foreach (var status in Enum.GetValues<ExamStatus>())
                    {
                        <option value="@status">@L[$"Enum:ExamStatus:{status}"]</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <select asp-for="AccessLevel" class="form-select">
                    <option value="">@L["Exams:AllAccessLevels"]</option>
                    @foreach (var accessLevel in Enum.GetValues<ExamAccessLevel>())
                    {
                        <option value="@accessLevel">@L[$"Enum:ExamAccessLevel:{accessLevel}"]</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <select asp-for="SelectionMode" class="form-select">
                    <option value="">@L["Exams:AllSelectionModes"]</option>
                    @foreach (var selectionMode in Enum.GetValues<ExamSelectionMode>())
                    {
                        <option value="@selectionMode">@L[$"Enum:ExamSelectionMode:{selectionMode}"]</option>
                    }
                </select>
            </div>
            <div class="col-lg-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["Exams:Search"]</button>
                <a class="btn btn-outline-secondary" href="/admin/exams">@L["Exams:Reset"]</a>
            </div>
        </form>

        <div id="examsTable" data-admin-refresh-url="@Model.BuildTableUrl()">
            <partial name="_Table" model="Model" />
        </div>
    </div>
</div>

<partial name="~/Pages/Shared/Admin/_AdminAjaxModal.cshtml" />
<script src="/js/admin/admin-crud-modal.js"></script>
