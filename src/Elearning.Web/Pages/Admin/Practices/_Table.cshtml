@model Elearning.Web.Pages.Admin.Practices.IndexModel
@using Elearning.Localization
@using Elearning.Practices
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

@if (Model.PracticeSets.Count == 0)
{
    <div class="alert alert-light border">@L["Practices:NoItems"]</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    @if (Model.CanDelete)
                    {
                        <th class="admin-question-selection-column">
                            <input type="checkbox"
                                   class="form-check-input"
                                   data-admin-select-all="[data-practice-row-checkbox]"
                                   aria-label="@L["Practices:SelectAll"]" />
                        </th>
                    }
                    <th>@L["Practices:TitleColumn"]</th>
                    <th>@L["Practices:AccessLevel"]</th>
                    <th>@L["Practices:SelectionMode"]</th>
                    <th>@L["Practices:QuestionCount"]</th>
                    <th class="text-end">@L["Practices:Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var practiceSet in Model.PracticeSets)
                {
                    <tr>
                        @if (Model.CanDelete)
                        {
                            <td class="admin-question-selection-column">
                                <input type="checkbox"
                                       class="form-check-input"
                                       value="@practiceSet.Id"
                                       data-practice-row-checkbox
                                       data-admin-selection-item
                                       aria-label="@L["Practices:SelectPractice"]" />
                            </td>
                        }
                        <td>
                            <strong>@practiceSet.Title</strong>
                            <div class="text-muted small">@practiceSet.Code</div>
                        </td>
                        <td>@L[$"Enum:PracticeAccessLevel:{practiceSet.AccessLevel}"]</td>
                        <td>@L[$"Enum:PracticeSelectionMode:{practiceSet.SelectionMode}"]</td>
                        <td>@practiceSet.AssignedQuestionCount / @practiceSet.TotalQuestionCount</td>
                        <td class="text-end">
                            <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                                <a class="btn btn-sm btn-outline-secondary" href="/admin/practices/preview/@practiceSet.Id">@L["Practices:Preview"]</a>
                                @if (Model.CanManageQuestions)
                                {
                                    <a class="btn btn-sm btn-outline-secondary" href="/admin/practices/questions/@practiceSet.Id">@L["Practices:ManageQuestions"]</a>
                                }
                                @if (Model.CanUpdate)
                                {
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/admin/practices/edit/@practiceSet.Id"
                                       data-admin-modal-url="/admin/practices/edit/@practiceSet.Id?handler=Modal"
                                       data-admin-modal-title="@L["Practices:EditTitle"]"
                                       data-admin-modal-size="lg">@L["Practices:Edit"]</a>
                                }
                                @if (Model.CanDelete)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@practiceSet.Id" data-admin-ajax-form="true" data-admin-refresh-target="#practiceSetsTable" onsubmit="return confirm('@L["Practices:ConfirmDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Practices:Delete"]</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Practices pagination" class="d-flex justify-content-between align-items-center mt-3">
        <span>@L["Practices:Page"] @Model.CurrentPage / @Model.TotalPages</span>
        <div class="d-flex gap-2">
            @if (Model.CurrentPage > 1)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
            }
        </div>
    </nav>
}
