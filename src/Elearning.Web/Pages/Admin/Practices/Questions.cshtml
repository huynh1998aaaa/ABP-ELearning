@page "/admin/practices/questions/{id:guid}"
@model Elearning.Web.Pages.Admin.Practices.QuestionsModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<section class="admin-workspace-page">
    <div class="admin-workspace-header mb-3">
        <a class="btn btn-link px-0 admin-workspace-backlink" href="/admin/practices">@L["Practices:BackToList"]</a>
        <h1 class="admin-workspace-page-title">@L["Practices:ManageQuestionsTitle"]</h1>
        <p class="admin-workspace-page-subtitle">@Model.PracticeSet.Title</p>
    </div>

    <form method="get" class="admin-workspace-toolbar row g-3 mb-4">
        <div class="col-lg-6">
            <input type="hidden" asp-for="Id" />
            <input asp-for="QuestionFilter" class="form-control" placeholder="@L["Practices:QuestionSearchPlaceholder"]" />
        </div>
        <div class="col-lg-6 d-flex gap-2 admin-workspace-toolbar-actions">
            <button type="submit" class="btn btn-primary">@L["Practices:Search"]</button>
            <a class="btn btn-outline-secondary" href="/admin/practices/questions/@Model.Id">@L["Practices:Reset"]</a>
            <a class="btn btn-outline-secondary" href="/admin/practices/preview/@Model.Id">@L["Practices:Preview"]</a>
        </div>
    </form>

    <div class="admin-workspace-toolbar row g-3 mb-4">
        <div class="col-lg-7">
            <form method="post"
                  asp-page-handler="AddByCount"
                  class="d-flex flex-wrap align-items-end gap-2"
                  data-admin-ajax-form="true"
                  data-admin-refresh-target="#practiceQuestionsWorkspace">
                <input type="hidden" asp-for="QuestionFilter" />
                <div class="admin-field-stack admin-field-compact">
                    <label asp-for="AddByCountInput.TargetQuestionCount" class="form-label">@L["Practices:TargetQuestionCount"]</label>
                    <input asp-for="AddByCountInput.TargetQuestionCount" class="form-control form-control-sm" min="1" max="1000" />
                </div>
                <button type="submit" class="btn btn-sm btn-primary">@L["Practices:AddByCount"]</button>
            </form>
        </div>
        <div class="col-lg-5 d-flex justify-content-lg-end align-items-end">
            <form method="post"
                  asp-page-handler="AddAll"
                  data-admin-ajax-form="true"
                  data-admin-refresh-target="#practiceQuestionsWorkspace"
                  data-admin-confirm-message="@L["Practices:BulkAddConfirmAll"]">
                <input type="hidden" asp-for="QuestionFilter" />
                <button type="submit" class="btn btn-sm btn-outline-primary">@L["Practices:AddAllQuestions"]</button>
            </form>
        </div>
    </div>

    <div id="practiceQuestionsWorkspace" class="admin-question-workspace-shell" data-admin-refresh-url="@Model.BuildWorkspaceUrl()">
        <partial name="_QuestionsWorkspace" model="Model" />
    </div>
</section>

<script src="/js/admin/admin-crud-modal.js"></script>
