@model Elearning.Web.Pages.Admin.Practices.QuestionsModel
@using Elearning.Localization
@using Elearning.Questions
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="admin-question-workspace">
    <section class="card admin-workspace-panel">
        <div class="card-header admin-workspace-panel-header">
            <div>
                <span class="fw-semibold">@L["Practices:AssignedQuestions"]</span>
                <div class="text-muted small">@L["Practices:AssignedQuestionCountSummary", Model.PracticeQuestions.Count, Model.PracticeSet.TotalQuestionCount]</div>
            </div>
        </div>
        <div class="card-body">
            @if (Model.PracticeQuestions.Count == 0)
            {
                <div class="alert alert-light border mb-0">@L["Practices:NoQuestions"]</div>
            }
            else
            {
                <div class="admin-assigned-list">
                    @foreach (var practiceQuestion in Model.PracticeQuestions)
                    {
                        <article class="admin-assigned-item">
                            <div class="admin-assigned-copy">
                                <strong>@practiceQuestion.QuestionTitle</strong>
                                <div class="text-muted small">@practiceQuestion.QuestionTypeName</div>
                                <span class="badge @(practiceQuestion.AssignmentSource == QuestionAssignmentSource.Auto ? "bg-info-subtle text-info-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                                    @L[$"Enum:QuestionAssignmentSource:{practiceQuestion.AssignmentSource}"]
                                </span>
                            </div>
                            <div class="admin-assigned-controls">
                                <form method="post"
                                      asp-page-handler="Update"
                                      asp-route-practiceQuestionId="@practiceQuestion.Id"
                                      class="admin-assigned-form"
                                      data-admin-ajax-form="true"
                                      data-admin-refresh-target="#practiceQuestionsWorkspace">
                                    <input name="UpdateInput.SortOrder" type="hidden" value="@practiceQuestion.SortOrder" />
                                    <label class="admin-inline-check">
                                        <input class="form-check-input" type="checkbox" name="UpdateInput.IsRequired" value="true" @(practiceQuestion.IsRequired ? "checked" : null) />
                                        <span>@L["Practices:IsRequired"]</span>
                                    </label>
                                    <button type="submit" class="btn btn-sm btn-outline-primary">@L["Practices:Save"]</button>
                                </form>
                                <form method="post"
                                      asp-page-handler="Remove"
                                      asp-route-practiceQuestionId="@practiceQuestion.Id"
                                      class="admin-inline-danger-form"
                                      data-admin-ajax-form="true"
                                      data-admin-refresh-target="#practiceQuestionsWorkspace"
                                      onsubmit="return confirm('@L["Practices:ConfirmRemoveQuestion"]');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@L["Practices:Remove"]</button>
                                </form>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>

    <section class="card admin-workspace-panel">
        <div class="card-header admin-workspace-panel-header">
            <span class="fw-semibold">@L["Practices:AvailableQuestions"]</span>
        </div>
        <div class="card-body">
            @if (Model.AvailableQuestions.Count == 0)
            {
                <div class="alert alert-light border mb-0">@L["Practices:NoAvailableQuestions"]</div>
            }
            else
            {
                <div class="admin-bank-list">
                    @foreach (var question in Model.AvailableQuestions)
                    {
                        <article class="admin-bank-item">
                            <div class="admin-bank-head">
                                <strong>@question.Title</strong>
                                <span class="badge bg-light text-dark">@question.QuestionTypeName</span>
                            </div>
                            <p class="admin-bank-body text-muted">@question.Content</p>
                            <form method="post"
                                  asp-page-handler="Add"
                                  class="admin-bank-add"
                                  data-admin-ajax-form="true"
                                  data-admin-refresh-target="#practiceQuestionsWorkspace">
                                <input type="hidden" name="AddInput.QuestionId" value="@question.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-success">@L["Practices:AddQuestion"]</button>
                            </form>
                        </article>
                    }
                </div>
            }
        </div>
    </section>
</div>
