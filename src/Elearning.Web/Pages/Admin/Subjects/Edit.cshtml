@page "/admin/subjects/edit/{id:guid}"
@model Elearning.Web.Pages.Admin.Subjects.EditModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin/subjects">@L["Subjects:BackToList"]</a>
    <h1 class="h3 mb-1">@L["Subjects:EditTitle"]</h1>
    <p class="text-muted mb-0">@L["Subjects:EditDescription"]</p>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" class="row g-3">
            <abp-validation-summary />

            <div class="col-md-6">
                <label asp-for="Input.Code" class="form-label">@L["Subjects:Code"]</label>
                <input asp-for="Input.Code" class="form-control" />
                <span asp-validation-for="Input.Code" class="text-danger"></span>
                <div class="form-text">@L["Subjects:CodeHelp"]</div>
            </div>

            <div class="col-md-6">
                <label asp-for="Input.Name" class="form-label">@L["Subjects:Name"]</label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Input.Description" class="form-label">@L["Subjects:Description"]</label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Input.SortOrder" class="form-label">@L["Subjects:SortOrder"]</label>
                <input asp-for="Input.SortOrder" class="form-control" />
                <span asp-validation-for="Input.SortOrder" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <span class="badge mt-md-4 @(Model.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                    @(Model.IsActive ? L["Subjects:IsActive"] : L["Subjects:Inactive"])
                </span>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["Subjects:Save"]</button>
                <a class="btn btn-outline-secondary" href="/admin/subjects">@L["Subjects:Cancel"]</a>
            </div>
        </form>
    </div>
</div>
