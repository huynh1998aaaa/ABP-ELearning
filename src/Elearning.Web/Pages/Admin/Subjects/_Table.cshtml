@model Elearning.Web.Pages.Admin.Subjects.IndexModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

@if (Model.Subjects.Count == 0)
{
    <div class="alert alert-light border">@L["Subjects:NoItems"]</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["Subjects:Code"]</th>
                    <th>@L["Subjects:Name"]</th>
                    <th>@L["Subjects:Description"]</th>
                    <th>@L["Subjects:SortOrder"]</th>
                    <th>@L["Subjects:Status"]</th>
                    <th class="text-end">@L["Subjects:Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subject in Model.Subjects)
                {
                    <tr>
                        <td><code>@subject.Code</code></td>
                        <td><strong>@subject.Name</strong></td>
                        <td class="text-muted">@(string.IsNullOrWhiteSpace(subject.Description) ? "-" : subject.Description)</td>
                        <td>@subject.SortOrder</td>
                        <td>
                            <span class="badge @(subject.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                                @(subject.IsActive ? L["Subjects:IsActive"] : L["Subjects:Inactive"])
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                @if (Model.CanUpdate)
                                {
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/admin/subjects/edit/@subject.Id"
                                       data-admin-modal-url="/admin/subjects/edit/@subject.Id?handler=Modal"
                                       data-admin-modal-title="@L["Subjects:EditTitle"]">@L["Subjects:Edit"]</a>
                                    @if (subject.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@subject.Id" data-admin-ajax-form="true" data-admin-refresh-target="#subjectsTable">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">@L["Subjects:Deactivate"]</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Activate" asp-route-id="@subject.Id" data-admin-ajax-form="true" data-admin-refresh-target="#subjectsTable">
                                            <button type="submit" class="btn btn-sm btn-outline-success">@L["Subjects:Activate"]</button>
                                        </form>
                                    }
                                }
                                @if (Model.CanDelete)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@subject.Id" data-admin-ajax-form="true" data-admin-refresh-target="#subjectsTable" onsubmit="return confirm('@L["Subjects:ConfirmDelete"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Subjects:Delete"]</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Subjects pagination" class="d-flex justify-content-between align-items-center mt-3">
        <span>@L["Subjects:Page"] @Model.CurrentPage / @Model.TotalPages</span>
        <div class="d-flex gap-2">
            @if (Model.CurrentPage > 1)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
            }
        </div>
    </nav>
}
