@model Elearning.Web.Pages.Admin.Questions.IndexModel
@using Elearning.Localization
@using Elearning.Questions
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

@if (Model.Questions.Count == 0)
{
    <div class="alert alert-light border">@L["Questions:NoItems"]</div>
}
else
{
    @if (Model.CanPublish)
    {
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="text-muted small">@L["Questions:BulkActions"]</span>
            <form method="post"
                  asp-page-handler="BulkPublish"
                  data-admin-ajax-form="true"
                  data-admin-bulk-form="true"
                  data-admin-selection-selector=".js-question-select:checked"
                  data-admin-selection-name="SelectedQuestionIds"
                  data-admin-no-selection-message="@L["Questions:BulkNoSelection"]"
                  data-admin-refresh-target="#questionsTable"
                  data-admin-confirm-message="@L["Questions:ConfirmBulkPublish"]">
                <div data-admin-selection-container></div>
                <button type="submit" class="btn btn-sm btn-success">@L["Questions:BulkPublish"]</button>
            </form>
            <form method="post"
                  asp-page-handler="BulkArchive"
                  data-admin-ajax-form="true"
                  data-admin-bulk-form="true"
                  data-admin-selection-selector=".js-question-select:checked"
                  data-admin-selection-name="SelectedQuestionIds"
                  data-admin-no-selection-message="@L["Questions:BulkNoSelection"]"
                  data-admin-refresh-target="#questionsTable"
                  data-admin-confirm-message="@L["Questions:ConfirmBulkArchive"]">
                <div data-admin-selection-container></div>
                <button type="submit" class="btn btn-sm btn-warning">@L["Questions:BulkArchive"]</button>
            </form>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    @if (Model.CanPublish)
                    {
                        <th class="text-center" style="width: 48px;">
                            <input class="form-check-input"
                                   type="checkbox"
                                   data-admin-select-all=".js-question-select"
                                   aria-label="@L["Questions:SelectAll"]" />
                        </th>
                    }
                    <th>@L["Questions:TitleColumn"]</th>
                    <th>@L["Questions:QuestionType"]</th>
                    <th>@L["Questions:Difficulty"]</th>
                    <th>@L["Questions:Score"]</th>
                    <th>@L["Questions:Status"]</th>
                    <th class="text-end">@L["Questions:Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var question in Model.Questions)
                {
                    <tr>
                        @if (Model.CanPublish)
                        {
                            <td class="text-center">
                                <input class="form-check-input js-question-select"
                                       type="checkbox"
                                       value="@question.Id"
                                       aria-label="@L["Questions:SelectQuestion"]" />
                            </td>
                        }
                        <td>
                            <strong>@question.Title</strong>
                            <div class="text-muted small">@question.Content</div>
                        </td>
                        <td>@question.QuestionTypeName</td>
                        <td>@L[$"Enum:QuestionDifficulty:{question.Difficulty}"]</td>
                        <td>@question.Score</td>
                        <td>
                            <span class="badge bg-info-subtle text-info-emphasis">@L[$"Enum:QuestionStatus:{question.Status}"]</span>
                            <span class="badge @(question.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                                @(question.IsActive ? L["Questions:IsActive"] : L["Questions:Inactive"])
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                                <a class="btn btn-sm btn-outline-secondary" href="/admin/questions/preview/@question.Id">@L["Questions:Preview"]</a>
                                @if (Model.CanUpdate)
                                {
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/admin/questions/edit/@question.Id"
                                       data-admin-modal-url="/admin/questions/edit/@question.Id?handler=Modal"
                                       data-admin-modal-title="@L["Questions:EditTitle"]"
                                       data-admin-modal-size="xl">@L["Questions:Edit"]</a>
                                    @if (question.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Deactivate" asp-route-id="@question.Id" data-admin-ajax-form="true" data-admin-refresh-target="#questionsTable">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">@L["Questions:Deactivate"]</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Activate" asp-route-id="@question.Id" data-admin-ajax-form="true" data-admin-refresh-target="#questionsTable">
                                            <button type="submit" class="btn btn-sm btn-outline-success">@L["Questions:Activate"]</button>
                                        </form>
                                    }
                                }
                                @if (Model.CanPublish)
                                {
                                    @if (question.Status != QuestionStatus.Published)
                                    {
                                        <form method="post" asp-page-handler="Publish" asp-route-id="@question.Id" data-admin-ajax-form="true" data-admin-refresh-target="#questionsTable">
                                            <button type="submit" class="btn btn-sm btn-outline-success">@L["Questions:Publish"]</button>
                                        </form>
                                    }
                                    @if (question.Status != QuestionStatus.Archived)
                                    {
                                        <form method="post" asp-page-handler="Archive" asp-route-id="@question.Id" data-admin-ajax-form="true" data-admin-refresh-target="#questionsTable">
                                            <button type="submit" class="btn btn-sm btn-outline-warning">@L["Questions:Archive"]</button>
                                        </form>
                                    }
                                }
                                @if (Model.CanDelete && question.Status == QuestionStatus.Archived)
                                {
                                    <form method="post"
                                          asp-page-handler="Delete"
                                          asp-route-id="@question.Id"
                                          data-admin-ajax-form="true"
                                          data-admin-refresh-target="#questionsTable"
                                          data-admin-confirm-message="@L["Questions:ConfirmHardDelete"]">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Questions:HardDelete"]</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Questions pagination" class="d-flex justify-content-between align-items-center mt-3">
        <span>@L["Questions:Page"] @Model.CurrentPage / @Model.TotalPages</span>
        <div class="d-flex gap-2">
            @if (Model.CurrentPage > 1)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
            }
        </div>
    </nav>
}
