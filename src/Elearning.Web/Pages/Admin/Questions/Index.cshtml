@page "/admin/questions"
@model Elearning.Web.Pages.Admin.Questions.IndexModel
@using Elearning.Localization
@using Elearning.Questions
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin">@L["Questions:BackToAdmin"]</a>
    <h1 class="h3 mb-1">@L["Questions:ListTitle"]</h1>
    <p class="text-muted mb-0">@L["Questions:ListSubtitle"]</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["Questions:Stats:Total"]</span>
                <div class="fs-2 fw-bold">@Model.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["Questions:Stats:Published"]</span>
                <div class="fs-2 fw-bold">@Model.PublishedCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["Questions:Stats:Draft"]</span>
                <div class="fs-2 fw-bold">@Model.DraftCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["Questions:Stats:Archived"]</span>
                <div class="fs-2 fw-bold">@Model.ArchivedCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <span class="fw-semibold">@L["Questions:Title"]</span>
        <div class="d-flex gap-2">
            @if (Model.CanImport)
            {
                <a class="btn btn-outline-primary btn-sm" href="/admin/questions/import">@L["Questions:Import:Title"]</a>
            }
            @if (Model.CanCreate)
            {
                <a class="btn btn-primary btn-sm" href="/admin/questions/create">@L["Questions:Create"]</a>
            }
        </div>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-lg-3">
                <input asp-for="Filter" class="form-control" placeholder="@L["Questions:SearchPlaceholder"]" />
            </div>
            <div class="col-lg-3">
                <select asp-for="QuestionTypeId" class="form-select">
                    <option value="">@L["Questions:AllQuestionTypes"]</option>
                    @foreach (var questionType in Model.QuestionTypes)
                    {
                        <option value="@questionType.Id">@questionType.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <select asp-for="Difficulty" class="form-select">
                    <option value="">@L["Questions:AllDifficulties"]</option>
                    @foreach (var difficulty in Enum.GetValues<QuestionDifficulty>())
                    {
                        <option value="@difficulty">@L[$"Enum:QuestionDifficulty:{difficulty}"]</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <select asp-for="Status" class="form-select">
                    <option value="">@L["Questions:AllStatuses"]</option>
                    @foreach (var status in Enum.GetValues<QuestionStatus>())
                    {
                        <option value="@status">@L[$"Enum:QuestionStatus:{status}"]</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["Questions:Search"]</button>
                <a class="btn btn-outline-secondary" href="/admin/questions">@L["Questions:Reset"]</a>
            </div>
        </form>

        @if (Model.Questions.Count == 0)
        {
            <div class="alert alert-light border">@L["Questions:NoItems"]</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>@L["Questions:TitleColumn"]</th>
                            <th>@L["Questions:QuestionType"]</th>
                            <th>@L["Questions:Difficulty"]</th>
                            <th>@L["Questions:Score"]</th>
                            <th>@L["Questions:Status"]</th>
                            <th class="text-end">@L["Questions:Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var question in Model.Questions)
                        {
                            <tr>
                                <td>
                                    <strong>@question.Title</strong>
                                    <div class="text-muted small">@question.Content</div>
                                </td>
                                <td>@question.QuestionTypeName</td>
                                <td>@L[$"Enum:QuestionDifficulty:{question.Difficulty}"]</td>
                                <td>@question.Score</td>
                                <td>
                                    <span class="badge bg-info-subtle text-info-emphasis">@L[$"Enum:QuestionStatus:{question.Status}"]</span>
                                    <span class="badge @(question.IsActive ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
                                        @(question.IsActive ? L["Questions:IsActive"] : L["Questions:Inactive"])
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                                        <a class="btn btn-sm btn-outline-secondary" href="/admin/questions/preview/@question.Id">@L["Questions:Preview"]</a>
                                        @if (Model.CanUpdate)
                                        {
                                            <a class="btn btn-sm btn-outline-primary" href="/admin/questions/edit/@question.Id">@L["Questions:Edit"]</a>
                                            @if (question.IsActive)
                                            {
                                                <form method="post" asp-page-handler="Deactivate" asp-route-id="@question.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">@L["Questions:Deactivate"]</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="Activate" asp-route-id="@question.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-success">@L["Questions:Activate"]</button>
                                                </form>
                                            }
                                        }
                                        @if (Model.CanPublish)
                                        {
                                            @if (question.Status != QuestionStatus.Published)
                                            {
                                                <form method="post" asp-page-handler="Publish" asp-route-id="@question.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-success">@L["Questions:Publish"]</button>
                                                </form>
                                            }
                                            @if (question.Status != QuestionStatus.Archived)
                                            {
                                                <form method="post" asp-page-handler="Archive" asp-route-id="@question.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">@L["Questions:Archive"]</button>
                                                </form>
                                            }
                                        }
                                        @if (Model.CanDelete)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@question.Id" onsubmit="return confirm('@L["Questions:ConfirmDelete"]');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">@L["Questions:Delete"]</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Questions pagination" class="d-flex justify-content-between align-items-center mt-3">
                <span>@L["Questions:Page"] @Model.CurrentPage / @Model.TotalPages</span>
                <div class="d-flex gap-2">
                    @if (Model.CurrentPage > 1)
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
                    }
                </div>
            </nav>
        }
    </div>
</div>
