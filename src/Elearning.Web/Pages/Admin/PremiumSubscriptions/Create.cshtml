@page "/admin/premiumsubscriptions/create"
@model Elearning.Web.Pages.Admin.PremiumSubscriptions.CreateModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin/premiumsubscriptions">@L["PremiumSubscriptions:BackToList"]</a>
    <h1 class="h3 mb-1">@L["PremiumSubscriptions:CreateTitle"]</h1>
    <p class="text-muted mb-0">@L["PremiumSubscriptions:CreateDescription"]</p>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" class="row g-3">
            <abp-validation-summary />

            <div class="col-md-6">
                <label asp-for="Input.UserId" class="form-label">@L["PremiumSubscriptions:User"]</label>
                <select asp-for="Input.UserId" asp-items="Model.UserOptions" class="form-select">
                    <option value="">@L["PremiumSubscriptions:SelectUser"]</option>
                </select>
                <span asp-validation-for="Input.UserId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Input.PremiumPlanId" class="form-label">@L["PremiumSubscriptions:Plan"]</label>
                <select asp-for="Input.PremiumPlanId" asp-items="Model.PlanOptions" class="form-select"></select>
                <span asp-validation-for="Input.PremiumPlanId" class="text-danger"></span>
                <div class="form-text">@L["PremiumSubscriptions:SixMonthsHelp"]</div>
            </div>

            <div class="col-12">
                <label asp-for="Input.Note" class="form-label">@L["PremiumSubscriptions:Note"]</label>
                <textarea asp-for="Input.Note" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Note" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="alert alert-info mb-0">
                    @L["PremiumSubscriptions:ActivationRule"]
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["PremiumSubscriptions:ActivatePremium"]</button>
                <a class="btn btn-outline-secondary" href="/admin/premiumsubscriptions">@L["PremiumSubscriptions:Cancel"]</a>
            </div>
        </form>
    </div>
</div>
