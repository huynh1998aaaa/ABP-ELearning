@model Elearning.Web.Pages.Admin.PremiumSubscriptions.IndexModel
@using Elearning.Localization
@using Elearning.PremiumSubscriptions
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

@if (Model.Subscriptions.Count == 0)
{
    <div class="alert alert-light border">@L["PremiumSubscriptions:NoItems"]</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@L["PremiumSubscriptions:User"]</th>
                    <th>@L["PremiumSubscriptions:Plan"]</th>
                    <th>@L["PremiumSubscriptions:ActivatedTime"]</th>
                    <th>@L["PremiumSubscriptions:ActivationNumber"]</th>
                    <th>@L["PremiumSubscriptions:EndTime"]</th>
                    <th>@L["PremiumSubscriptions:RemainingDays"]</th>
                    <th>@L["PremiumSubscriptions:Status"]</th>
                    <th class="text-end">@L["PremiumSubscriptions:Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subscription in Model.Subscriptions)
                {
                    <tr>
                        <td>
                            <strong>@subscription.UserName</strong>
                            <div class="text-muted small">@subscription.Email</div>
                        </td>
                        <td>@subscription.PremiumPlanName</td>
                        <td>@subscription.ActivatedTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@subscription.ActivationNumber</td>
                        <td>@subscription.EndTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@subscription.RemainingDays</td>
                        <td>
                            <span class="badge @GetStatusBadge(subscription.Status)">
                                @L[$"Enum:PremiumSubscriptionStatus:{subscription.Status}"]
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <a class="btn btn-sm btn-outline-primary"
                                   href="/admin/premiumsubscriptions/edit/@subscription.Id"
                                   data-admin-modal-url="/admin/premiumsubscriptions/edit/@subscription.Id?handler=Modal"
                                   data-admin-modal-title="@L["PremiumSubscriptions:EditTitle"]"
                                   data-admin-modal-size="lg">@L["PremiumSubscriptions:Edit"]</a>
                                @if (Model.CanUpdate && subscription.IsCurrentlyActive)
                                {
                                    <form method="post" asp-page-handler="Extend" asp-route-id="@subscription.Id" data-admin-ajax-form="true" data-admin-refresh-target="#premiumSubscriptionsTable">
                                        <button type="submit" class="btn btn-sm btn-outline-success">@L["PremiumSubscriptions:Extend"]</button>
                                    </form>
                                }
                                @if (Model.CanCancel && subscription.IsCurrentlyActive)
                                {
                                    <form method="post" asp-page-handler="Cancel" asp-route-id="@subscription.Id" data-admin-ajax-form="true" data-admin-refresh-target="#premiumSubscriptionsTable" onsubmit="return confirm('@L["PremiumSubscriptions:ConfirmCancel"]');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["PremiumSubscriptions:CancelPremium"]</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Premium subscriptions pagination" class="d-flex justify-content-between align-items-center mt-3">
        <span>@L["PremiumSubscriptions:Page"] @Model.CurrentPage / @Model.TotalPages</span>
        <div class="d-flex gap-2">
            @if (Model.CurrentPage > 1)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage - 1)">Prev</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@Model.BuildPageUrl(Model.CurrentPage + 1)">Next</a>
            }
        </div>
    </nav>
}

@functions {
    private static string GetStatusBadge(PremiumSubscriptionStatus status)
    {
        return status switch
        {
            PremiumSubscriptionStatus.Active => "bg-success-subtle text-success-emphasis",
            PremiumSubscriptionStatus.Expired => "bg-warning-subtle text-warning-emphasis",
            PremiumSubscriptionStatus.Cancelled => "bg-secondary-subtle text-secondary-emphasis",
            _ => "bg-light text-dark"
        };
    }
}
