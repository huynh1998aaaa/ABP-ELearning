@page "/admin/premiumsubscriptions"
@model Elearning.Web.Pages.Admin.PremiumSubscriptions.IndexModel
@using Elearning.Localization
@using Elearning.PremiumSubscriptions
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="mb-3">
    <a class="btn btn-link px-0" href="/admin">@L["PremiumSubscriptions:BackToAdmin"]</a>
    <h1 class="h3 mb-1">@L["PremiumSubscriptions:ListTitle"]</h1>
    <p class="text-muted mb-0">@L["PremiumSubscriptions:ListSubtitle"]</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["PremiumSubscriptions:Stats:Total"]</span>
                <div class="fs-2 fw-bold">@Model.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["PremiumSubscriptions:Stats:Active"]</span>
                <div class="fs-2 fw-bold">@Model.ActiveCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["PremiumSubscriptions:Stats:Expired"]</span>
                <div class="fs-2 fw-bold">@Model.ExpiredCount</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <span>@L["PremiumSubscriptions:Stats:Cancelled"]</span>
                <div class="fs-2 fw-bold">@Model.CancelledCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <span class="fw-semibold">@L["PremiumSubscriptions:Title"]</span>
        @if (Model.CanCreate)
        {
            <a class="btn btn-primary btn-sm"
               href="/admin/premiumsubscriptions/create"
               data-admin-modal-url="/admin/premiumsubscriptions/create?handler=Modal"
               data-admin-modal-title="@L["PremiumSubscriptions:CreateTitle"]"
               data-admin-modal-size="lg">@L["PremiumSubscriptions:Create"]</a>
        }
    </div>
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-lg-6">
                <input asp-for="Filter" class="form-control" placeholder="@L["PremiumSubscriptions:SearchPlaceholder"]" />
            </div>
            <div class="col-lg-3">
                <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select>
            </div>
            <div class="col-lg-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@L["PremiumSubscriptions:Search"]</button>
                <a class="btn btn-outline-secondary" href="/admin/premiumsubscriptions">@L["PremiumSubscriptions:Reset"]</a>
            </div>
        </form>

        <div id="premiumSubscriptionsTable" data-admin-refresh-url="@Model.BuildTableUrl()">
            <partial name="_Table" model="Model" />
        </div>
    </div>
</div>

<partial name="~/Pages/Shared/Admin/_AdminAjaxModal.cshtml" />
<script src="/js/admin/admin-crud-modal.js"></script>
