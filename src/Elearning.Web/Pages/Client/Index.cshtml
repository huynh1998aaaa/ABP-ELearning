@page "/client"
@model Elearning.Web.Pages.Client.IndexModel
@using Elearning.ClientContent
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<section class="section-panel client-shell">
    <header class="client-topbar">
        <a class="client-brand" href="/client">OMD.TestGo V3.5</a>

        <div class="client-topbar-actions">
            <div class="client-user">
                <div class="client-user-line">
                    <span class="client-user-icon" aria-hidden="true"></span>
                    <strong>@(Model.UserName ?? "Guest")</strong>
                </div>
                <span class="client-status-badge @(Model.IsPremium ? "client-status-premium" : "client-status-free")">
                    @(Model.IsPremium ? L["Client:PremiumStatus"] : L["Client:FreeStatus"])
                </span>
            </div>

            <div class="client-toolbar-actions">
                <button type="button"
                        class="client-action-button client-action-premium"
                        data-premium-contact-open
                        aria-haspopup="dialog"
                        aria-controls="premium-contact-dialog">
                    @L["Client:UpgradePremium"]
                </button>
                <a class="client-action-button client-action-logout" href="/client/logout">
                    @L["Auth:Logout"]
                </a>
            </div>
        </div>
    </header>

    <div class="client-announcement client-announcement-highlight">
        @if (Model.IsPremium)
        {
            <span>@L["Client:Announcement:Premium"]</span>
        }
        else
        {
            <span>@L["Client:Announcement:Free"]</span>
        }
    </div>

    <section class="learning-section">
        <div class="learning-section-header">
            <div class="learning-section-title">
                <span class="section-icon section-icon-free">FREE</span>
                <h2>@L["Client:FreeSectionTitle"]</h2>
            </div>
            <span class="section-badge">@L["Enum:ClientLearningAccessLevel:Free"]</span>
        </div>
        <div class="learning-grid">
            @if (Model.FreeItems.Count == 0)
            {
                <div class="learning-empty">@L["Client:NoFreeItems"]</div>
            }
            else
            {
                @foreach (var item in Model.FreeItems)
                {
                    <partial name="_LearningItemCard" model="item" />
                }
            }
        </div>
    </section>

    <section class="learning-section learning-section-premium">
        <div class="learning-section-header">
            <div class="learning-section-title">
                <span class="section-icon section-icon-premium">PREMIUM</span>
                <h2>@L["Client:PremiumSectionTitle"]</h2>
            </div>
            <span class="section-badge section-badge-premium">@L["Enum:ClientLearningAccessLevel:Premium"]</span>
        </div>
        <div class="learning-grid">
            @if (Model.PremiumItems.Count == 0)
            {
                <div class="learning-empty">@L["Client:NoPremiumItems"]</div>
            }
            else
            {
                @foreach (var item in Model.PremiumItems)
                {
                    <partial name="_LearningItemCard" model="item" />
                }
            }
        </div>
    </section>
</section>

<div class="premium-contact-modal"
     id="premium-contact-dialog"
     data-premium-contact-modal
     hidden
     aria-hidden="true">
    <div class="premium-contact-backdrop" data-premium-contact-close></div>

    <div class="premium-contact-dialog"
         role="dialog"
         aria-modal="true"
         aria-label="@L["Client:PremiumPopupQrAlt"]">
        <button type="button"
                class="premium-contact-close"
                data-premium-contact-close
                aria-label="@L["Client:PremiumPopupClose"]">
            <span aria-hidden="true">&times;</span>
        </button>

        <div class="premium-contact-card">
            <div class="premium-contact-image-frame">
                <img src="/images/premium/QR.jpg"
                     alt="@L["Client:PremiumPopupQrAlt"]"
                     class="premium-contact-full-image"
                     data-premium-qr-image />
                <div class="premium-contact-qr-fallback"
                     data-premium-qr-fallback
                     hidden>
                    <strong>@L["Client:PremiumPopupQrMissingTitle"]</strong>
                    <p>@L["Client:PremiumPopupQrMissingDescription"]</p>
                    <code>/wwwroot/images/premium/QR.jpg</code>
                </div>
            </div>
        </div>
    </div>
</div>
