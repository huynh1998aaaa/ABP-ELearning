@page "/client/login"
@model Elearning.Web.Pages.Client.LoginModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-lg-5 text-center">
                    <span class="badge bg-info-subtle text-info-emphasis mb-3">@L["Auth:ClientPortal"]</span>
                    <h1 class="h3 mb-3">@L["Auth:ClientLoginTitle"]</h1>
                    <p class="text-muted">@L["Auth:ClientLoginDescription"]</p>

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-warning text-start">@Model.ErrorMessage</div>
                    }

                    <a class="btn btn-primary w-100" href="/client/login?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">
                        @L["Auth:LoginWithGoogle"]
                    </a>

                    <div class="mt-4 d-flex justify-content-center gap-3">
                        <a href="/">@L["Auth:BackHome"]</a>
                        <a href="/admin/login">@L["Auth:AdminLoginLink"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
