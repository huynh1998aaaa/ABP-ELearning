@page "/client/session/{id:guid}"
@model Elearning.Web.Pages.Client.SessionModel
@using System
@using Elearning.Localization
@using Elearning.QuestionTypes
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<section class="session-shell"
         data-session-root="true"
         data-submit-url="@Url.Page("/Client/Session", new { id = Model.Session.Id, handler = "Submit" })"
         data-result-url="@Url.Page("/Client/Result", new { id = Model.Session.Id })"
         data-submit-confirm="@L["Client:SubmitConfirm"]"
         data-essay-saving-text="@L["Client:EssayAutosaving"]"
         data-essay-saved-text="@L["Client:EssayAutosaved"]"
         data-essay-save-failed-text="@L["Client:EssayAutosaveFailed"]"
         data-end-time="@(Model.Session.EndsAt?.ToString("O") ?? string.Empty)">
    <div class="session-stage">
        <div class="session-sticky-stack">
            <div class="session-header">
                <div class="session-title-row">
                    <span class="session-title-icon" aria-hidden="true"></span>
                    <h1>@L["Client:RuntimeTitle", Model.Session.Title]</h1>
                </div>
                <div class="session-progress">
                    <div class="session-progress-bar">
                        <div class="session-progress-fill" style="width:@(Model.Session.TotalQuestionCount == 0 ? 0 : (Model.Session.AnsweredCount * 100 / Model.Session.TotalQuestionCount))%"></div>
                    </div>
                </div>
            </div>

            <div class="session-control-panel">
                <div class="session-control-main">
                    <div class="session-timer-card">
                        <span class="session-control-label">@L["Client:TimeRemaining"]</span>
                        <strong data-session-timer>
                            @(Model.Session.EndsAt.HasValue ? "--:--" : L["Client:NoTimeLimit"])
                        </strong>
                    </div>

                    <div class="session-action-row">
                        <a class="session-action session-action-leave" href="/client">
                            @L["Client:LeaveSession"]
                        </a>

                        <button type="button" class="session-action session-action-submit" data-session-submit>
                            @L["Client:SubmitSession"]
                        </button>
                    </div>
                </div>

                <div class="session-nav-panel">
                    <div class="session-control-label">@L["Client:QuestionNavigator"]</div>
                    <div class="session-nav-grid">
                        @foreach (var question in Model.Session.Questions)
                        {
                            <button type="button"
                                    class="session-nav-item @(question.IsAnswered ? "session-nav-answered" : "session-nav-unanswered") @(question.SortOrder == 1 ? "session-nav-current" : string.Empty)"
                                    data-session-nav
                                    data-question-target="question-@question.Id"
                                    data-question-id="@question.Id">
                                @question.SortOrder
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="session-layout">
            <main class="session-questions">
                @foreach (var question in Model.Session.Questions)
                {
                    var isEssay = string.Equals(question.QuestionTypeCode, QuestionTypeCodes.Essay, StringComparison.Ordinal);
                    var isMatching = string.Equals(question.QuestionTypeCode, QuestionTypeCodes.Matching, StringComparison.Ordinal);
                    var inputType = string.Equals(question.QuestionTypeCode, QuestionTypeCodes.MultipleChoice, StringComparison.Ordinal)
                        ? "checkbox"
                        : "radio";

                    <section id="question-@question.Id" class="question-runtime-card" data-question-panel="@question.Id">
                        <div class="question-runtime-accent"></div>
                        <div class="question-runtime-body">
                            <h2>@L["Client:QuestionHeading", question.SortOrder, question.Title, question.OriginalQuestionId.ToString("N")[..4]]</h2>

                            <form method="post"
                                  asp-page-handler="SaveAnswer"
                                  asp-route-id="@Model.Session.Id"
                                  class="question-answer-form"
                                  data-answer-form="true"
                                  data-question-id="@question.Id">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="questionId" value="@question.Id" />

                                @if (isEssay)
                                {
                                    <div class="essay-answer-panel">
                                        <textarea name="EssayAnswerText"
                                                  rows="10"
                                                  class="form-control essay-textarea"
                                                  data-essay-input="true"
                                                  data-max-words="@(question.EssayMaxWords?.ToString() ?? string.Empty)">@question.EssayAnswerText</textarea>

                                        <div class="essay-meta">
                                            @if (question.EssayMaxWords.HasValue)
                                            {
                                                <span class="essay-counter">
                                                    <span>@L["Client:EssayWordCount"]</span>
                                                    <strong data-essay-counter="true">@($"0 / {question.EssayMaxWords.Value}")</strong>
                                                </span>
                                            }

                                            <span class="essay-status" data-essay-status="true">@L["Client:EssayAutosaved"]</span>
                                        </div>
                                    </div>
                                }
                                else if (isMatching)
                                {
                                    <div class="matching-runtime-board"
                                         data-matching-board="true"
                                         data-matching-waiting-text="@L["Client:MatchingWaiting"]"
                                         data-matching-active-prompt="@L["Client:MatchingActivePrompt"]"
                                         data-matching-active-template="@L["Client:MatchingActivePair", "{0}"]"
                                         data-matching-connected-template="@L["Client:MatchingConnectedTo", "{0}"]"
                                         data-matching-choice-used-template="@L["Client:MatchingChoiceUsedBy", "{0}"]"
                                         data-matching-summary-template="@L["Client:MatchingSummaryCount", "{0}", "{1}"]"
                                         data-matching-no-connections="@L["Client:MatchingNoConnectionsYet"]"
                                         data-matching-select-question-first="@L["Client:MatchingSelectQuestionFirst"]"
                                         data-matching-choice-used-error="@L["Client:MatchingRightChoiceAlreadyUsed"]">
                                        <div class="matching-runtime-intro">
                                            <div class="matching-runtime-intro-copy">
                                                <span class="matching-runtime-intro-title">@L["Client:MatchingSummaryTitle"]</span>
                                                <p>@L["Client:MatchingInstruction"]</p>
                                            </div>
                                            <strong class="matching-runtime-progress" data-matching-progress="true">
                                                @L["Client:MatchingSummaryCount", 0, question.MatchingPairs.Count]
                                            </strong>
                                        </div>

                                        <div class="matching-runtime-layout" data-matching-layout="true">
                                            <section class="matching-runtime-column">
                                                <div class="matching-runtime-column-head">
                                                    <span>@L["Client:MatchingQuestionsColumn"]</span>
                                                </div>

                                                <div class="matching-runtime-left-list">
                                                    @for (var index = 0; index < question.MatchingPairs.Count; index++)
                                                    {
                                                        var pair = question.MatchingPairs[index];
                                                        var selectedRightText = pair.SelectedRightText ?? string.Empty;

                                                        <article class="matching-runtime-left-item @(string.IsNullOrEmpty(selectedRightText) ? string.Empty : "matching-runtime-left-item-connected")"
                                                                 data-matching-left-item="true"
                                                                 data-pair-id="@pair.Id"
                                                                 data-pair-order="@(index + 1)">
                                                            <input type="hidden" name="MatchingAnswers[@index].PairId" value="@pair.Id" />
                                                            <input type="hidden"
                                                                   name="MatchingAnswers[@index].SelectedRightText"
                                                                   value="@selectedRightText"
                                                                   data-matching-hidden="true" />

                                                            <div class="matching-runtime-left-head">
                                                                <span class="matching-runtime-order">@(index + 1)</span>
                                                                <span class="matching-runtime-left-label">@question.QuestionTypeName</span>
                                                            </div>
                                                            <strong class="matching-runtime-left-text">@pair.LeftText</strong>
                                                            <span class="matching-runtime-left-state" data-matching-left-state="true">
                                                                @(string.IsNullOrWhiteSpace(selectedRightText)
                                                                    ? L["Client:MatchingWaiting"]
                                                                    : L["Client:MatchingConnectedTo", selectedRightText])
                                                            </span>
                                                            <span class="matching-runtime-left-selected"
                                                                  data-matching-left-selected="true"
                                                                  @(string.IsNullOrWhiteSpace(selectedRightText) ? "hidden" : null)>@selectedRightText</span>
                                                        </article>
                                                    }
                                                </div>
                                            </section>

                                            <div class="matching-runtime-link-layer" aria-hidden="true">
                                                <svg class="matching-runtime-link-svg" data-matching-svg="true"></svg>
                                            </div>

                                            <aside class="matching-runtime-center-panel">
                                                <div class="matching-runtime-center-card">
                                                    <span class="matching-runtime-center-label">@L["Client:MatchingSelectPlaceholder"]</span>
                                                    <strong data-matching-active-label="true">@L["Client:MatchingActivePrompt"]</strong>
                                                    <button type="button"
                                                            class="matching-runtime-clear"
                                                            data-matching-clear="true"
                                                            disabled>
                                                        @L["Client:MatchingClearCurrent"]
                                                    </button>
                                                </div>

                                                <div class="matching-runtime-summary-list" data-matching-summary-list="true">
                                                    <div class="matching-runtime-summary-empty">@L["Client:MatchingNoConnectionsYet"]</div>
                                                </div>
                                            </aside>

                                            <section class="matching-runtime-column">
                                                <div class="matching-runtime-column-head">
                                                    <span>@L["Client:MatchingAnswersColumn"]</span>
                                                </div>

                                                <div class="matching-runtime-right-list" role="group" aria-label="@L["Client:MatchingAnswersColumn"]">
                                                    @foreach (var choice in question.MatchingChoices)
                                                    {
                                                        var isSelected = question.MatchingPairs.Any(x => string.Equals(x.SelectedRightText, choice, StringComparison.Ordinal));

                                                        <button type="button"
                                                                class="matching-bank-choice @(isSelected ? "matching-bank-choice-used" : string.Empty)"
                                                                data-matching-choice="true"
                                                                data-value="@choice">
                                                            <span class="matching-bank-choice-dot" aria-hidden="true"></span>
                                                            <span class="matching-bank-choice-text">@choice</span>
                                                            <span class="matching-bank-choice-meta" data-matching-choice-meta="true"></span>
                                                        </button>
                                                    }
                                                </div>
                                            </section>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="question-option-list">
                                        @foreach (var option in question.Options)
                                        {
                                            var isChecked = question.SelectedOptionIds.Contains(option.Id);
                                            <label class="question-option-item">
                                                <input type="@inputType"
                                                       name="SelectedOptionIds"
                                                       value="@option.Id"
                                                       @(isChecked ? "checked" : null) />
                                                <span>@option.Text</span>
                                            </label>
                                        }
                                    </div>
                                }
                            </form>
                        </div>
                    </section>
                }
            </main>
        </div>
    </div>
</section>

<script src="/js/client/client-learning-session.js"></script>
