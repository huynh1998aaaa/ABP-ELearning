@page "/client/google-callback"
@model Elearning.Web.Pages.Client.GoogleCallbackModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-lg-5 text-center">
                    <h1 class="h3 mb-3">@L["Auth:GoogleLoginFailedTitle"]</h1>
                    <p class="text-muted">@L["Auth:GoogleLoginFailedDescription"]</p>

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-warning text-start">@Model.ErrorMessage</div>
                    }

                    <a class="btn btn-primary w-100" href="/client/login?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">
                        @L["Auth:TryGoogleLoginAgain"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
