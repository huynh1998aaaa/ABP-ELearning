@page "/"
@model Elearning.Web.Pages.IndexModel
@using Elearning.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ElearningResource> L
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OMD.TestGo</title>
    <link rel="stylesheet" href="/global-styles.css" />
    <link rel="stylesheet" href="/css/home/home.css" />
</head>
<body>
    <main class="client-entry-shell">
        <section class="client-entry-stage">
            <header class="client-entry-topbar">
                <a class="client-entry-brand" href="/">
                    <span class="client-entry-brand-mark">O</span>
                    <span>OMD.TestGo</span>
                </a>

                <span class="client-entry-admin-hint">/admin</span>
            </header>

            <div class="client-entry-grid">
                <section class="client-entry-hero">
                    <span class="client-entry-eyebrow">@L["Landing:Eyebrow"]</span>
                    <h1>@L["Landing:Title"]</h1>
                    <p>@L["Landing:Subtitle"]</p>

                    <div class="client-entry-actions">
                        <a class="client-entry-google" href="/client/login">@L["Auth:LoginWithGoogle"]</a>
                    </div>

                    <div class="client-entry-pills" aria-label="@L["Landing:TrustTitle"]">
                        <span>@L["Landing:TrustExam"]</span>
                        <span>@L["Landing:TrustPractice"]</span>
                        <span>@L["Landing:TrustPremium"]</span>
                    </div>
                </section>

                <aside class="client-entry-side" aria-label="@L["Landing:PreviewTitle"]">
                    <div class="client-entry-side-head">
                        <span>@L["Auth:ClientPortal"]</span>
                        <strong>@L["Landing:PreviewTitle"]</strong>
                    </div>

                    <div class="client-entry-flow">
                        <article>
                            <span>01</span>
                            <h2>@L["Landing:PreviewExamTitle"]</h2>
                            <p>@L["Landing:PreviewExamDescription"]</p>
                        </article>
                        <article>
                            <span>02</span>
                            <h2>@L["Landing:PreviewPracticeTitle"]</h2>
                            <p>@L["Landing:PreviewPracticeDescription"]</p>
                        </article>
                        <article>
                            <span>03</span>
                            <h2>@L["Landing:PreviewProgressTitle"]</h2>
                            <p>@L["Landing:PreviewProgressDescription"]</p>
                        </article>
                    </div>
                </aside>
            </div>
        </section>
    </main>
</body>
</html>
